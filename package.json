{
	"name": "@sigrea/use",
	"version": "0.1.0",
	"description": "Signal-powered, framework-agnostic utility hooks built on @sigrea/core.",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sigrea/use.git"
	},
	"homepage": "https://github.com/sigrea/use#readme",
	"bugs": {
		"url": "https://github.com/sigrea/use/issues"
	},
	"engines": {
		"node": ">=24"
	},
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"keywords": [
		"signals",
		"reactivity",
		"hooks",
		"composables",
		"typescript",
		"dom"
	],
	"scripts": {
		"build": "unbuild",
		"prepack": "unbuild",
		"changelog": "changelogen",
		"release": "pnpm test && pnpm build && changelogen --release",
		"test": "vitest run",
		"test:coverage": "vitest --coverage",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"format": "biome check .",
		"format:fix": "biome check --write .",
		"cicheck": "pnpm test && pnpm typecheck && pnpm format:fix"
	},
	"peerDependencies": {
		"@sigrea/core": "^0.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@sigrea/core": "^0.6.0",
		"@vitest/coverage-v8": "^3.2.4",
		"changelogen": "^0.6.2",
		"jsdom": "^24.1.3",
		"lefthook": "1.13.6",
		"tsx": "^4.20.5",
		"typescript": "5.9.3",
		"unbuild": "3.6.1",
		"vitest": "^3.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["lefthook", "@biomejs/biome"]
	}
}
